# Copy these values into Streamlit Community Cloud > App settings > Secrets.
# Never commit a real secrets.toml file.

APP_ENV = "production"
DATABASE_URL = "postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
SESSION_TIMEOUT_MINUTES = 480

[auth]
[[auth.users]]
email = "consultant@example.com"
display_name = "Consultant"
role = "Consultant"
# Use either password or password_hash. password_hash is SHA-256 for this shell.
password = "replace-this-password"

[[auth.users]]
email = "leadership@example.com"
display_name = "Leadership"
role = "Leadership"
password = "replace-this-password"
